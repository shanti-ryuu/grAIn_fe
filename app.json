{
  "expo": {
    "name": "grAIn",
    "slug": "grAIn-fe",
    "scheme": "grain",
    "version": "1.0.0",
    "platforms": ["ios", "android"],
    "ios": {
      "icon": "./assets/icon.png"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-secure-store",
        {
          "faceIDPermission": "Allow $(PRODUCT_NAME) to access your face ID"
        }
      ]
    ]
  }
}
