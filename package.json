{
  "name": "grain-fe",
  "version": "1.0.0",
  "description": "grAIn - Farmer-facing Expo mobile app for IoT Smart Grain Dryer",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "start:clear": "expo start --clear",
    "dev": "expo start",
    "web": "expo start --web",
    "ios": "expo start --ios",
    "android": "expo start --android",
    "lint": "eslint . --ext .tsx,.ts",
    "type-check": "tsc --noEmit",
    "eas:build:ios": "eas build --platform ios",
    "eas:build:android": "eas build --platform android",
    "eas:build:all": "eas build --platform all"
  },
  "dependencies": {
    "@react-navigation/bottom-tabs": "^7.15.9",
    "@react-navigation/drawer": "^7.9.8",
    "@react-navigation/native": "^6.1.18",
    "@react-navigation/native-stack": "^6.11.0",
    "axios": "^1.15.1",
    "expo": "~54.0.0",
    "expo-constants": "~18.0.13",
    "expo-linking": "~8.0.11",
    "expo-router": "^55.0.12",
    "expo-secure-store": "~55.0.13",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-worklets": "^0.8.1",
    "react-native-worklets-core": "^1.6.3"
  },
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/plugin-proposal-decorators": "^7.23.0",
    "@types/react": "^18.2.0",
    "@types/react-native": "^0.72.0",
    "babel-preset-expo": "^11.0.0",
    "eslint": "^8.51.0",
    "eslint-config-expo": "^9.0.0",
    "typescript": "^5.2.2"
  },
  "private": true,
  "expo": {
    "plugins": [
      [
        "expo-secure-store",
        {
          "faceIDPermission": "Allow $(PRODUCT_NAME) to access your face ID"
        }
      ]
    ]
  }
}
